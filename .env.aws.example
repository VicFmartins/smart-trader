APP_ENV=production
PROJECT_NAME=CarteiraConsol
APP_VERSION=0.1.0
LOG_LEVEL=INFO
PORT=8000

# RDS PostgreSQL
DATABASE_URL=postgresql+psycopg://app_user:CHANGE_ME@carteiraconsol.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/carteiraconsol

# Raw storage on AWS S3
RAW_STORAGE_MODE=s3
S3_BUCKET_NAME=carteiraconsol-raw-prod
S3_BUCKET_PREFIX=incoming/
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=
S3_USE_PATH_STYLE=false

# Prefer IAM roles in AWS runtimes. Leave static credentials empty in ECS/Lambda.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# API auth
JWT_SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ALERTS_ENABLED=true
ALERT_PROVIDER=sns
ALERT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:carteiraconsol-ingestion-alerts

# Production schema management should use Alembic, not create_all()
AUTO_CREATE_TABLES=false
API_PREFIX=
