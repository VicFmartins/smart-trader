# ════════════════════════════════════════════════════════════════════════════
#  Smart Trade — Environment Variables
#  Copy this file to .env and fill in your own values.
#  NEVER commit the real .env file to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: "gemini" or "ollama"
LLM_PROVIDER=gemini

# ── Gemini (Google AI) ───────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60

# ── Ollama (local inference) ─────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite local (default). Path is relative to the project root.
# DATABASE_URL=sqlite:///./data/smart_trade.db
AUTO_CREATE_TABLES=true

# ── Authentication (JWT) ─────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-before-any-deployment
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Default admin user (created on first run if AUTO_CREATE_TABLES=true) ─────
DEFAULT_ADMIN_EMAIL=admin@smarttrade.local
DEFAULT_ADMIN_PASSWORD=change-me-now

# ── Streamlit → API connection ────────────────────────────────────────────────
SMART_TRADE_API_URL=http://127.0.0.1:8010
